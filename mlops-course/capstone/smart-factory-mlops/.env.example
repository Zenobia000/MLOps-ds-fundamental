# =============================================================================
# .env.example — 環境變數範本（複製成 .env 後填入；.env 不進 Git）
# -----------------------------------------------------------------------------
# 重要：本檔只放「佔位值」，絕不放真實密鑰 / token / 連線字串。
# 用法：cp .env.example .env  然後依本地環境調整。
# =============================================================================

# --- MLflow 實驗追蹤 ---------------------------------------------------------
# 本地用 docker-compose 起的 server；雲端改成你的 tracking server URL。
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT=smart-factory
# 若 tracking server 有開啟認證，這裡放佔位（請改用 secret manager）。
MLFLOW_TRACKING_USERNAME=__CHANGE_ME__
MLFLOW_TRACKING_PASSWORD=__CHANGE_ME__

# --- Feast 特徵商店 ----------------------------------------------------------
# 指向 feature_repo 目錄（feature_store.yaml 所在處）。
FEAST_REPO=./feature_repo

# --- 模型產物路徑 ------------------------------------------------------------
MODELS_DIR=./models
TABULAR_MODEL_PATH=./models/xgboost_maintenance.json
VISION_MODEL_PATH=./models/defect_resnet.onnx
TIMESERIES_MODEL_PATH=./models/lstm_demand.pt

# --- 資料路徑（DVC 追蹤，預設不進 Git）--------------------------------------
DATA_RAW=./data/raw
DATA_PROCESSED=./data/processed

# --- DVC 遠端儲存（選配；本地玩具流程可不設）-------------------------------
# 真實環境填 S3/GCS bucket；金鑰請走環境/IAM，勿寫死在此。
DVC_REMOTE_URL=__CHANGE_ME__

# --- 服務設定 ----------------------------------------------------------------
SERVICE_HOST=0.0.0.0
SERVICE_PORT=3000

# --- 雜項 --------------------------------------------------------------------
LOG_LEVEL=INFO
RANDOM_SEED=42
