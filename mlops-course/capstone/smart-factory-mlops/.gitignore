# =============================================================================
# .gitignore — Smart Factory MLOps Capstone
# -----------------------------------------------------------------------------
# 原則：資料與模型產物走 DVC / registry，不進 Git；只保留目錄佔位 .gitkeep。
# =============================================================================

# --- Python ------------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/
.ipynb_checkpoints/

# --- 環境與密鑰（絕不上 Git）------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key

# --- MLflow 產物 -------------------------------------------------------------
mlruns/
mlartifacts/

# --- 監控報告產物（make monitor 產出的 Evidently HTML）-----------------------
monitoring/reports/

# --- DVC pipeline 產物（reports/metrics.json 由 evaluate 階段產生）------------
reports/

# --- 模型產物（DVC / registry 管理）-----------------------------------------
# 注意：用 /models/ 錨定根目錄，否則會誤殺原始碼 src/models/。
/models/
*.onnx
*.pt
*.pth
*.pkl
*.joblib

# --- 資料庫 / 序列化大檔 -----------------------------------------------------
*.db
*.sqlite
*.parquet

# --- 資料（DVC 追蹤；保留目錄結構的 .gitkeep）-------------------------------
# 用 dir/* 忽略「內容」而非「目錄本身」，否則 .gitkeep 的 !negation 無法生效
# （git 無法 re-include 已被排除的父目錄底下的檔案）。
data/raw/*
data/interim/*
data/processed/*
data/external/*
!data/**/.gitkeep

# --- Feast 線上 store 本地檔 -------------------------------------------------
feature_repo/data/*
!feature_repo/data/.gitkeep
feature_repo/*.db

# --- DVC 暫存 ----------------------------------------------------------------
/.dvc/cache
/.dvc/tmp

# --- 編輯器 / 系統 -----------------------------------------------------------
.vscode/
.idea/
.DS_Store
*.swp
